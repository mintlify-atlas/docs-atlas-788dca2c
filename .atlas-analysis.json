  "keyFeatures": [
    "Rotational kinetic network with stress-capacity balance",
    "Moving contraptions (pistons, bearings, elevators, trains)",
    "Fluid piping, pumps, and tank connectivity",
    "Logistics automation (belts, funnels, filters, packaging)",
    "Full train/railway system with scheduling and signals",
    "In-game interactive Ponder documentation system",
    "Rich addon API for extending contraptions, recipes, and registries",
    "CC: Tweaked (ComputerCraft) integration for scripted automation",
    "Schematic and quill for blueprint saving and placement",
    "JEI/REI recipe viewer integration"
  ],
  "publicApiSurface": [
    "BlockMovementChecks — register/query contraption movement rules",
    "MovementBehaviour / MovementBehaviour.REGISTRY — actor behaviors on contraptions",
    "BlockStressValues.IMPACTS / CAPACITIES / RPM — stress registries",
    "CreateRegistries — ResourceKeys for all Create registries",
    "CreateBuiltInRegistries — built-in registry instances",
    "FanProcessingType — register custom fan processing recipes",
    "MountedItemStorageType / MountedFluidStorageType — contraption storage types",
    "ContraptionType — register custom contraption types",
    "DisplaySource / DisplayTarget — display link integration",
    "PotatoCannonProjectileType — custom potato cannon projectiles",
    "BlockEntityBehaviourEvent — attach behaviours to SmartBlockEntities",
    "PipeCollisionEvent — fluid pipe collision callbacks",
    "TrackGraphMergeEvent — railway graph merge callbacks",
    "BlockSpoutingBehaviour / CauldronSpoutingBehavior — spout interactions",
    "BaseRecipeProvider / StandardProcessingRecipeGen — addon recipe data providers",
    "SafeNbtWriterRegistry / SchematicRequirementRegistries — schematic extensions",
    "ConnectivityHandler — fluid/tank connectivity API",
    "BoilerHeater — register custom boiler heat sources",
    "IHaveGoggleInformation / IHaveHoveringInformation — goggle overlay info"
  ]
}
